# Deepor MCP Translation Server — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Backend selection ──────────────────────────────────────────────────────
# Choose one: openai | anthropic | ollama | deepl
TRANSLATE_BACKEND=openai

# ── OpenAI (TRANSLATE_BACKEND=openai) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic (TRANSLATE_BACKEND=anthropic) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Ollama — local, no API key needed (TRANSLATE_BACKEND=ollama) ──────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── DeepL (TRANSLATE_BACKEND=deepl) ───────────────────────────────────────
DEEPL_API_KEY=...
# Set to "true" if using the DeepL free-tier API
DEEPL_FREE_API=false
